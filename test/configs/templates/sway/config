### Variables
set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term = kitty
set $menu bemenu-run

### Output configuration

### Input configuration
input "type:keyboard" {
  xkb_layout us,ru
  xkb_model pc105
  xkb_options ctrl:nocaps,grp:toggle
  xkb_variant ""
}

input "type:touchpad" {
  dwt true
  natural_scroll true
  tap true
}

seat "*" {
  xcursor_theme Adwaita 16
}

### Key bindings
bindsym --to-code Mod4+0 workspace number 0
bindsym --to-code Mod4+1 workspace number 1
bindsym --to-code Mod4+2 workspace number 2
bindsym --to-code Mod4+3 workspace number 3
bindsym --to-code Mod4+4 workspace number 4
bindsym --to-code Mod4+5 workspace number 5
bindsym --to-code Mod4+6 workspace number 6
bindsym --to-code Mod4+7 workspace number 7
bindsym --to-code Mod4+8 workspace number 8
bindsym --to-code Mod4+9 workspace number 9

bindsym --to-code Mod4+Shift+0 move container to workspace number 0
bindsym --to-code Mod4+Shift+1 move container to workspace number 1
bindsym --to-code Mod4+Shift+2 move container to workspace number 2
bindsym --to-code Mod4+Shift+3 move container to workspace number 3
bindsym --to-code Mod4+Shift+4 move container to workspace number 4
bindsym --to-code Mod4+Shift+5 move container to workspace number 5
bindsym --to-code Mod4+Shift+6 move container to workspace number 6
bindsym --to-code Mod4+Shift+7 move container to workspace number 7
bindsym --to-code Mod4+Shift+8 move container to workspace number 8
bindsym --to-code Mod4+Shift+9 move container to workspace number 9

bindsym --to-code Mod4+Shift+Comma move workspace to output left
bindsym --to-code Mod4+Shift+Period move workspace to output right

bindsym --to-code Mod4+Shift+Down move down
bindsym --to-code Mod4+Shift+Left move left
bindsym --to-code Mod4+Shift+Right move right
bindsym --to-code Mod4+Shift+Up move up

bindsym --to-code Mod4+Shift+h move left
bindsym --to-code Mod4+Shift+j move down
bindsym --to-code Mod4+Shift+k move up
bindsym --to-code Mod4+Shift+l move right
bindsym --to-code Mod4+Shift+minus move scratchpad
bindsym --to-code Mod4+Shift+space floating toggle

bindsym --to-code Mod4+Comma focus output left
bindsym --to-code Mod4+Period focus output right

bindsym --to-code Mod4+Down focus down
bindsym --to-code Mod4+F4 exec pamixer -t
bindsym --to-code Mod4+Left focus left
bindsym --to-code Mod4+Mod1+space exec darkman toggle

bindsym --to-code Mod4+Right focus right
bindsym --to-code Mod4+Up focus up
bindsym --to-code Mod4+j focus down
bindsym --to-code Mod4+k focus up
bindsym --to-code Mod4+l focus right
bindsym --to-code Mod4+space focus mode_toggle

bindsym --to-code Mod4+p exec $menu
bindsym --to-code Mod4+Print exec screenshot-edit
bindsym --to-code Mod4+Shift+Backspace exec swaylock -c 000000
bindsym --to-code Mod4+Backspace exec ~/dotfiles/scripts/t
bindsym --to-code Mod4+Shift+Return exec kitty --working-directory `swaycwd`
bindsym --to-code Mod4+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -b 'Yes, exit sway' 'swaymsg exit'

bindsym --to-code Mod4+i exec pkill -USR2 -u $USER waybar || true
bindsym --to-code Mod4+Shift+i exec pkill -USR1 -u $USER waybar || true

bindsym --to-code Print exec screenshot
bindsym --to-code XF86AudioLowerVolume exec pamixer -d 2
bindsym --to-code XF86AudioMute exec pamixer -t
bindsym --to-code XF86AudioRaiseVolume exec pamixer -i 2

bindsym --to-code Mod4+Shift+c reload

bindsym --to-code Mod4+a focus parent
bindsym --to-code Mod4+b splith
bindsym --to-code Mod4+e layout toggle split
bindsym --to-code Mod4+f fullscreen toggle
bindsym --to-code Mod4+h focus left
bindsym --to-code Mod4+minus scratchpad show
bindsym --to-code Mod4+q kill

bindsym --to-code Mod4+r mode resize

bindsym --to-code Mod4+s layout stacking
bindsym --to-code Mod4+v splitv
bindsym --to-code Mod4+w layout tabbed

mode "resize" {
  bindsym --to-code Down resize grow height 10 px
  bindsym --to-code Escape mode default
  bindsym --to-code Left resize shrink width 10 px
  bindsym --to-code Return mode default
  bindsym --to-code Right resize grow width 10 px
  bindsym --to-code Up resize shrink height 10 px
  bindsym --to-code h resize shrink width 10 px
  bindsym --to-code j resize grow height 10 px
  bindsym --to-code k resize shrink height 10 px
  bindsym --to-code l resize grow width 10 px
}


