[{
  "name": "main",
  "reload_style_on_change" : true,
  "position": "top",
  "height": 30,
  "layer": "bottom",
  "modules-center": [
    "sway/window"
  ],
  "modules-left": [
    "sway/workspaces",
    "sway/mode"
  ],
  "modules-right": [
    "tray",
    "pulseaudio",
    "battery",
    "clock",
    "sway/language"
  ],

  "backlight": {
    "format": "{icon}",
    "format-alt": "{percent}% {icon}",
    "format-alt-click": "click-right",
    "format-icons": [
      "ïƒ«",
      "ï™²"
    ],
    "on-scroll-down": "light -A 1",
    "on-scroll-up": "light -U 1"
  },
  "battery": {
    "format": "{capacity}% {icon} ",
    "format-charging": "{capacity}% َ°‚„",
    "format-icons": [
      "َ°‚ژ",
      "َ°پ؛",
      "َ°پ»",
      "َ°پ¼",
      "َ°پ½",
      "َ°پ¾",
      "َ°پ؟",
      "َ°‚€",
      "َ°‚پ",
      "َ°‚‚",
      "َ°پ¹"
    ],
    "format-plugged": "{capacity}% َ°ڑ¥",
    "interval": 30,
    "states": {
      "critical": 1,
      "warning": 25
    },
    "tooltip": false
  },
  "clock": {
    "format": "{:%a %a %d %b %H:%M}",
    "tooltip": false
  },
  "custom/storage": {
    "exec": "~/.config/waybar/modules/storage.sh",
    "format": "{} ï‚ ",
    "format-alt": "{percentage}% ï‚ ",
    "format-alt-click": "click-right",
    "interval": 60,
    "return-type": "json"
  },
  "custom/test": {
    "exec": "/tmp/test blub",
    "format": "{}",
    "interval": 5,
    "param": "blah"
  },
  "pulseaudio": {
    "format": "{volume}% {icon}  {format_source}",
    "format-bluetooth": "{volume}% {icon}ïٹ” {format_source}",
    "format-bluetooth-muted": "َ°—؟ {icon}ïٹ” {format_source}",
    "format-icons": {
      "car": "ï†¹",
      "default": [
        "َ°•؟",
        "َ°–€",
        "َ°•¾"
      ],
      "headphone": "ï€¥",
      "phone": "ï‚•",
      "portable": "ï‚•"
    },
    "format-muted": "َ°‌ں  {format_source}",
    "format-source": "َ°چ¬",
    "format-source-muted": "َ°چ­",
    "on-click": "pavucontrol"
  },
  "sway/language": {
    "format": "{flag}",
    "on-click": "swaymsg input type:keyboard xkb_switch_layout next"
  },
  "sway/mode": {
    "format": "ïپ”ï„… {}"
  },
  "sway/window": {
    "max-length": "80",
    "rewrite": {
      "(.*) - Brave": "َ°‡§  $1 - Brave",
      "nvim (.*)": "ïچ¯  $1"
    },
    "tooltip": false
  },
  "sway/workspaces": {
    "disable-scroll": true,
    "format": "{name}"
  },
  "tray": {
    "icon-size": 18
  }
}]
