[{
  "name": "main",
  "reload_style_on_change" : true,
  "position": "top",
  "height": 30,
  "layer": "bottom",
  "modules-left": [
    "hyprland/workspaces"
  ],
  "modules-center": [
    "hyprland/window"
  ],
  "modules-right": [
    "tray",
    "pulseaudio",
    "battery",
    "clock",
    "sway/language",
    "hyprland/language"
  ],
  "hyprland/workspaces": {
	  "format": "{name}",
  },
  "hyprland/window": {
    "format": "ΏθΣΚ {}",
    "rewrite": {
        "(.*) έΑΦ Mozilla Firefox": "ΏθΝΟ $1",
        "(.*) - fish": "> [$1]"
    },
    "separate-outputs": true
  },
  "hyprland/language": {
    "format": "Lang: {}",
    "format-en": "US",
    "format-ru": "ru",
    "keyboard-name": "at-translated-set-2-keyboard"
  },

  "backlight": {
    "format": "{icon}",
    "format-alt": "{percent}% {icon}",
    "format-alt-click": "click-right",
    "format-icons": [
      "ΎΔτ",
      "Ύβ▓"
    ],
    "on-scroll-down": "light -A 1",
    "on-scroll-up": "light -U 1"
  },
  "battery": {
    "format": "{capacity}% {icon} ",
    "format-charging": "{capacity}% ≤░ΓΕ",
    "format-icons": [
      "≤░ΓΟ",
      "≤░Β║",
      "≤░Β╗",
      "≤░Β╝",
      "≤░Β╜",
      "≤░Β╛",
      "≤░Β┐",
      "≤░ΓΑ",
      "≤░ΓΒ",
      "≤░ΓΓ",
      "≤░Β╣"
    ],
    "format-plugged": "{capacity}% ≤░γξ",
    "interval": 30,
    "states": {
      "critical": 1,
      "warning": 25
    },
    "tooltip": false
  },
  "clock": {
    "format": "{:%a %a %d %b %H:%M}",
    "tooltip": false
  },
  "pulseaudio": {
    "format": "{volume}% {icon}  {format_source}",
    "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
    "format-bluetooth-muted": "≤░Ω┐ {icon}ΎΛΦ {format_source}",
    "format-icons": {
      "car": "ΎΗ╣",
      "default": [
        "≤░Χ┐",
        "≤░ΨΑ",
        "≤░Χ╛"
      ],
      "headphone": "ΎΑξ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ"
    },
    "format-muted": "≤░ζθ  {format_source}",
    "format-source": "≤░Ξυ",
    "format-source-muted": "≤░Ξφ",
    "on-click": "pavucontrol"
  },
  "tray": {
    "icon-size": 18
  }
}]
