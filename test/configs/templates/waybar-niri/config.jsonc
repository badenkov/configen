[
  {
    "name": "main",
    "reload_style_on_change": true,
    "position": "top",
    "height": 30,
    "layer": "bottom",
    "modules-left": ["niri/workspaces"],
    "modules-center": ["niri/window"],
    "modules-right": [
      "tray",
      "clock",
      "pulseaudio",
      "battery",
      "niri/language",
    ],
    "niri/workspaces": {
      "format": "{icon}",
      "format-icons": {
        // Named workspaces
        // (you need to configure them in niri)
        "browser": "ο£à",
        "project": "ο΅â",
        "chat": "σΑçΞ",
        "notes": "σΑΚΩ",
        "configs": "σΑΔΜ",
        "default": "ο³ë",
      },
    },
    "niri/window": {
      "format": "{}",
      "separate-outputs": true,
    },
    "niri/language": {
      "format": "{}",
      "format-en": "ο³€ US",
      "format-ru": "ο³€ RU",
      "keyboard-name": "keyd-virtual-keyboard",
    },

    "backlight": {
      "format": "{icon}",
      "format-alt": "{percent}% {icon}",
      "format-alt-click": "click-right",
      "format-icons": ["οÉΪ"],
      "on-scroll-down": "light -A 1",
      "on-scroll-up": "light -U 1",
    },
    "battery": {
      "format": "{capacity}% {icon} ",
      "format-charging": "{capacity}% σΑ²³",
      "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
      "format-plugged": "{capacity}% σΑöΞ",
      "interval": 30,
      "states": {
        "critical": 1,
        "warning": 25,
      },
      "tooltip": false,
    },
    "clock": {
      "format": "{:%H:%M}",
      "format-alt": "{:%A, %B %d, %Y (%R)} ο¹≥",
      "tooltip": true,
      "tooltip-format": "<tt><small>{calendar}</small></tt>",
      "calendar": {
        "mode": "month",
        "mode-mon-col": 3,
        "weeks-pos": "right",
        "on-scroll": 1,
        "format": {
          "months": "<span color='#ffead3'><b>{}</b></span>",
          "days": "<span color='#ecc6d9'><b>{}</b></span>",
          "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
          "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
          "today": "<span color='#ff6699'><b><u>{}</u></b></span>",
        },
      },
      "actions": {
        "on-click-right": "mode",
        "on-scroll-up": "tz_up",
        "on-scroll-down": "tz_down",
        "on-scroll-up": "shift_up",
        "on-scroll-down": "shift_down",
      },
    },
    "pulseaudio": {
      "format": "{volume}% {icon}  {format_source}",
      "format-bluetooth": "{volume}% {icon}οäî {format_source}",
      "format-bluetooth-muted": "σΑ½Ω {icon}οäî {format_source}",
      "format-icons": {
        "car": "οÜΙ",
        "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"],
        "headphone": "οÄΞ",
        "phone": "ο²ï",
        "portable": "ο²ï",
      },
      "format-muted": "σΑùü  {format_source}",
      "format-source": "σΑç§",
      "format-source-muted": "σΑç≠",
      "on-click": "pavucontrol",
    },
    "tray": {
      "icon-size": 14,
    },
  },
]
